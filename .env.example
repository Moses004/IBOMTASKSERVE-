# Copy this file to .env and fill in your own Supabase project's values.
# Find these under Project Settings > API in the Supabase dashboard.
# .env is git-ignored — never commit your real .env file.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Paystack PUBLIC key only (starts with pk_live_ or pk_test_) — this one is
# meant to be visible in client-side code, so it's safe to keep in .env.
#
# Do NOT put your Paystack SECRET key (sk_live_.../sk_test_...) anywhere in
# this file, the frontend code, or in chat with any AI assistant. It must
# only be set as a Supabase Edge Function secret:
#   Supabase Dashboard > Project Settings > Edge Functions > Secrets
#   Add: PAYSTACK_SECRET_KEY = sk_live_xxxxxxxx
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
